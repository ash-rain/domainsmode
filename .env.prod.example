# DomainsMode — Production Environment
# Copy to .env on the VPS and fill in real values.
# NEVER commit this file with real secrets.

DOMAIN=domainsmode.nsh.one
CERTBOT_EMAIL=admin@nsh.one

# Database
DB_PASSWORD=CHANGE_ME_strong_random_password

# Laravel APP_KEYs (generate with: php artisan key:generate --show)
APP_KEY_API=base64:CHANGE_ME
APP_KEY_UI=base64:CHANGE_ME

# API Bearer tokens (generate with: openssl rand -hex 32)
API1_KEY=CHANGE_ME
API2_KEY=CHANGE_ME
